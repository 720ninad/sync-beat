PORT=3000
NODE_ENV=development

# Neon PostgreSQL — use the *pooled* connection string from console.neon.tech
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

JWT_SECRET=

# Optional — forgot-password OTP emails
RESEND_API_KEY=
FROM_EMAIL=

# Upstash Redis — must start with rediss://
REDIS_URL=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=syncbeat-tracks
R2_PUBLIC_URL=

# Optional — WebRTC TURN (falls back to Google STUN if unset)
METERED_API_KEY=
METERED_DOMAIN=
